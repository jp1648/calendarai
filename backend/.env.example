# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# LLM (required)
OPENROUTER_API_KEY=your-openrouter-key

# Web search (required for agent web_search tool)
TAVILY_API_KEY=your-tavily-key

# Google/Gmail OAuth (required for Gmail integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/gmail/callback
GOOGLE_PUBSUB_TOPIC=projects/your-project/topics/gmail-push

# Calendly OAuth (optional — needed for Calendly integration)
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
CALENDLY_REDIRECT_URI=http://localhost:8000/api/calendly/callback

# Resy (optional — scraped automatically if not set)
RESY_API_KEY=

